{
  "kind": "Config",
  "apiVersion": "v1",
  "preferences": {},
  "clusters": [
    {
      "name": "my-cluster",
      "cluster": {
        "server": "https://my.cluster.domain:443",
        "certificate-authority-data": "<base64 encoded cluster CA certificate>"
      }
    }
  ],
  "users": [
    {
      "name": "keyfactor-orchestrator",
      "user": {
        "client-certificate-data": "<base64 encoded client certificate (PEM)>",
        "client-key-data": "<base64 encoded client private key (PEM)>"
      }
    }
  ],
  "contexts": [
    {
      "name": "keyfactor-orchestrator-context",
      "context": {
        "cluster": "my-cluster",
        "user": "keyfactor-orchestrator",
        "namespace": "default"
      }
    }
  ],
  "current-context": "keyfactor-orchestrator-context"
}
