<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="keyfactor-github" value="https://nuget.pkg.github.com/Keyfactor/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- Default: use nuget.org for all packages -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!-- Keyfactor packages come from GitHub Packages (case-insensitive patterns) -->
    <packageSource key="keyfactor-github">
      <package pattern="Keyfactor.*" />
      <package pattern="keyfactor.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <keyfactor-github>
      <add key="Username" value="GH_USER" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </keyfactor-github>
  </packageSourceCredentials>
</configuration>
